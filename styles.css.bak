
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Serif', sans-serif; 
    background-color: #222; 
    color: #1167b1;
}



.header {
    background-color: #222;
    color: #fff;
    padding: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: fixed;
    width: 100%;
	z-index: 1000;
}


.logo-container {
    display: flex;
    align-items: center;
}

.logo {
    max-width: 80px;
    height: auto;
    margin-right: 20px;
    font-size: 24px; 
}


.title {
    font-size: 50px;
	font-weight: bold;
}


.search-container {
    display: flex;
    align-items: center;
}

.search-input {
    padding: 8px;
    border: none;
    border-radius: 5px;
    margin-right: 10px;
    font-size: 16px;
}

.search-button {
    padding: 8px 16px;
    border: none;
    border-radius: 5px;
    background-color: #333;
    color: #fff;
    cursor: pointer;
    font-size: 16px;
}

.search-button:hover {
    background-color: #555;
}

.vertical-nav {
    position: fixed;
	top: 140px; 
    left: 0;
    bottom: 0;
    background-color: #222;
    width: 200px;
    padding: 40px 0;
    overflow-y: auto;
    z-index: 1;
}


.vertical-nav ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
}

.vertical-nav li {
    margin-bottom: 15px;
}

.vertical-nav a {
    display: block;
    color: #fff;
    text-decoration: none;
    padding: 10px;
    transition: all 0.3s ease;
	font-weight: bold;
	font-size: 18px;
}


.vertical-nav a:hover {
    background-color: #555;
}

.slideshow-container {
    position: fixed;
    top: calc(100px + 20px + 20px); 
    left: calc(200px + 20px); 
    right: 0;
    bottom: 0;
    max-width: calc(100% - 240px); 
    overflow: hidden;
    z-index: 1; 
}

.slide {
    position: absolute;
    width: 100%;
    height: 100%;
    display: none;
}

.slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.caption {
    position: absolute;
    bottom: 8px;
    left: 8px;
    background-color: rgba(0, 0, 0, 0.5);
    color: #fff;
    padding: 5px 10px;
}

.prev, .next {
    cursor: pointer;
    position: absolute;
    top: 50%;
    width: auto;
    padding: 16px;
    margin-top: -22px;
    color: #fff;
    font-size: 20px;
    transition: 0.6s ease;
    border-radius: 0 3px 3px 0;
    user-select: none;
}

.next {
    right: 0;
    border-radius: 3px 0 0 3px;
}

.prev:hover, .next:hover {
    background-color: rgba(0, 0, 0, 0.8);
}

footer {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: #222;
    padding: 10px;
    z-index: 2;
}

.footer-links a {
    color: #fff;
    text-decoration: none;
    margin-right: 20px;
}



.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 20px;
	margin-left: 250px;
	height: 500px;
}



.video-container iframe:hover {
    transform: scale(1.05);
}


.movies-section {
    margin-top: 140px; 
    padding: 20px;
}

.movies-section h2 {
    font-size: 28px;
    color: #fff;
    margin-bottom: 20px;
}

.mrow {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

.movie {
    flex: 1 0 calc(33.333% - 20px);
    background-color: #333;
    border-radius: 10px;
    overflow: hidden;
    transition: transform 0.3s ease;
    cursor: pointer;
}

.movie:hover {
    transform: scale(1.05);
}

.movie-img {
    width: 100%;
    height: 300px; 
    overflow: hidden;
}

.movie-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.movie-info {
    padding: 15px;
}

.movie-info h3 {
    font-size: 20px;
    color: #fff;
    margin-bottom: 10px;
}

.movie-info p {
    font-size: 14px;
    color: #ccc;
}

.movie-popup {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9999;
}

.movie-popup-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: #fff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.3);
    animation: fadeIn 0.3s ease;
}

.movie-popup-close {
    position: absolute;
    top: 10px;
    right: 10px;
    cursor: pointer;
    font-size: 20px;
    color: #666;
    transition: color 0.3s ease;
}

.movie-popup-close:hover {
    color: #333;
}

.slideshow-container {
    position: relative;
    height: 400px; 
    margin-bottom: 200px; 
}

.trailer-container {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
    gap: 20px;
	padding-left: 250px;
}

.trailer {
    flex: 0 0 auto;
    margin-right: 20px;
    max-width: 400px;
    height: auto;
}

.trailer img {
    width: 300px;
    height: 300px; 
    object-fit: cover; 
}